{
  "name": "@harness-one/dogfood",
  "version": "0.0.4",
  "private": true,
  "description": "Dogfood agent — issue triage bot that runs harness-one against real GitHub issues so adapter / guardrail / RAG regressions surface in production, not in user bug reports.",
  "type": "module",
  "scripts": {
    "triage": "tsx src/entry.ts",
    "weekly": "tsx src/weekly.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/"
  },
  "dependencies": {
    "harness-one": "workspace:*",
    "@harness-one/preset": "workspace:*",
    "@harness-one/anthropic": "workspace:*"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  }
}
