{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "exactOptionalPropertyTypes": false
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist", "tmp"]
}
