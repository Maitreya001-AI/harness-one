node_modules/
dist/
coverage/
coverage-temp/
*.tsbuildinfo
tsup.config.bundled_*.mjs
.claude/
tmp/

# api-extractor scratch dir (contents regenerated on each
# `pnpm api:update`; the committed baseline lives under packages/*/etc/).
packages/*/temp/

# Stryker mutation testing scratch dir (reports + incremental cache)
.stryker-tmp/

# typedoc output — the docs-api CI job uses typedoc purely as a gate
# (invalid @links / not-exported references fail CI); the HTML bundle
# itself is not a shipped artifact.
.typedoc/

# lychee link-checker persistent cache (keyed by commit SHA in CI;
# regenerated locally each run).
.lycheecache
