node_modules/
dist/
coverage/
coverage-temp/
*.tsbuildinfo
tsup.config.bundled_*.mjs
.claude/*
# Friction-logging automation (see docs/harness-one-feedback-automation.md)
# is shared across contributors — keep its files tracked even though the
# rest of .claude/ (worktrees, scheduled_tasks.lock, local caches) stays local.
!.claude/feedback-instructions.md
!.claude/commands/
tmp/

# api-extractor scratch dir (contents regenerated on each
# `pnpm api:update`; the committed baseline lives under packages/*/etc/).
packages/*/temp/

# Stryker mutation testing scratch dir (reports + incremental cache)
.stryker-tmp/

# typedoc output — the docs-api CI job uses typedoc purely as a gate
# (invalid @links / not-exported references fail CI); the HTML bundle
# itself is not a shipped artifact.
.typedoc/

# lychee link-checker persistent cache (keyed by commit SHA in CI;
# regenerated locally each run).
.lycheecache

# size-limit pre-bundled fixtures (regenerated by `pnpm size`).
tools/size-check/bundles/

# tree-shake fixture output (regenerated by `pnpm check:tree-shake`).
tools/tree-shake-check/out/

# dogfood per-run reports are kept in the Actions-artifact / weekly-rollup
# loop, not in the repo. Only the dated weekly summary markdowns are
# committed.
dogfood-reports/runs/
!dogfood-reports/weekly-*.md
