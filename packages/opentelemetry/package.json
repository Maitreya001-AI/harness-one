{
  "name": "@harness-one/opentelemetry",
  "version": "0.1.0",
  "description": "OpenTelemetry trace exporter for harness-one",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "harness-one": "workspace:*"
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1.0.0"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT",
  "author": "harness-one contributors",
  "keywords": ["opentelemetry", "tracing", "observability", "ai", "adapter"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Maitreya001-AI/harness-one",
    "directory": "packages/opentelemetry"
  },
  "bugs": {
    "url": "https://github.com/Maitreya001-AI/harness-one/issues"
  },
  "homepage": "https://github.com/Maitreya001-AI/harness-one#readme"
}
