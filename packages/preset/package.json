{
  "name": "@harness-one/preset",
  "version": "0.1.0",
  "description": "Batteries-included harness-one preset with all integrations",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "harness-one": "workspace:*",
    "@harness-one/anthropic": "workspace:*",
    "@harness-one/openai": "workspace:*",
    "@harness-one/ajv": "workspace:*",
    "@harness-one/devkit": "workspace:*"
  },
  "optionalDependencies": {
    "@harness-one/redis": "workspace:*",
    "@harness-one/langfuse": "workspace:*",
    "@harness-one/opentelemetry": "workspace:*",
    "@harness-one/tiktoken": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "author": "harness-one contributors",
  "keywords": ["ai", "agent", "harness", "preset", "full", "batteries-included"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Maitreya001-AI/harness-one",
    "directory": "packages/preset"
  },
  "bugs": {
    "url": "https://github.com/Maitreya001-AI/harness-one/issues"
  },
  "homepage": "https://github.com/Maitreya001-AI/harness-one#readme"
}
