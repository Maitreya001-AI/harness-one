{
  "name": "@harness-one/anthropic",
  "version": "0.1.4",
  "description": "Anthropic SDK adapter for harness-one",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "harness-one": "workspace:*"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "license": "MIT",
  "author": "harness-one contributors",
  "keywords": [
    "anthropic",
    "claude",
    "ai",
    "adapter"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Maitreya001-AI/harness-one",
    "directory": "packages/anthropic"
  },
  "bugs": {
    "url": "https://github.com/Maitreya001-AI/harness-one/issues"
  },
  "homepage": "https://github.com/Maitreya001-AI/harness-one#readme"
}
