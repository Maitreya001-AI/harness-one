{
  "name": "@harness-one/ajv",
  "version": "0.1.0",
  "description": "Ajv JSON Schema validator for harness-one",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "harness-one": "workspace:*"
  },
  "peerDependencies": {
    "ajv": ">=8.0.0",
    "ajv-formats": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "ajv-formats": {
      "optional": true
    }
  },
  "devDependencies": {
    "ajv": "^8.0.0",
    "ajv-formats": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT",
  "author": "harness-one contributors",
  "keywords": ["ajv", "json-schema", "validation", "ai", "harness"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Maitreya001-AI/harness-one",
    "directory": "packages/ajv"
  },
  "bugs": {
    "url": "https://github.com/Maitreya001-AI/harness-one/issues"
  },
  "homepage": "https://github.com/Maitreya001-AI/harness-one#readme"
}
