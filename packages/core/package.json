{
  "name": "harness-one",
  "version": "0.1.0",
  "description": "Universal primitives for AI agent harness engineering",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
