{
  "name": "harness-one",
  "version": "1.0.2",
  "description": "Universal primitives for AI agent harness engineering",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/cjs/core/index.cjs"
    },
    "./advanced": {
      "types": "./dist/advanced/index.d.ts",
      "import": "./dist/advanced/index.js",
      "require": "./dist/cjs/advanced/index.cjs"
    },
    "./prompt": {
      "types": "./dist/prompt/index.d.ts",
      "import": "./dist/prompt/index.js",
      "require": "./dist/cjs/prompt/index.cjs"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "import": "./dist/context/index.js",
      "require": "./dist/cjs/context/index.cjs"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js",
      "require": "./dist/cjs/tools/index.cjs"
    },
    "./guardrails": {
      "types": "./dist/guardrails/index.d.ts",
      "import": "./dist/guardrails/index.js",
      "require": "./dist/cjs/guardrails/index.cjs"
    },
    "./observe": {
      "types": "./dist/observe/index.d.ts",
      "import": "./dist/observe/index.js",
      "require": "./dist/cjs/observe/index.cjs"
    },
    "./session": {
      "types": "./dist/session/index.d.ts",
      "import": "./dist/session/index.js",
      "require": "./dist/cjs/session/index.cjs"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js",
      "require": "./dist/cjs/memory/index.cjs"
    },
    "./evolve-check": {
      "types": "./dist/evolve-check/index.d.ts",
      "import": "./dist/evolve-check/index.js",
      "require": "./dist/cjs/evolve-check/index.cjs"
    },
    "./rag": {
      "types": "./dist/rag/index.d.ts",
      "import": "./dist/rag/index.js",
      "require": "./dist/cjs/rag/index.cjs"
    },
    "./orchestration": {
      "types": "./dist/orchestration/index.d.ts",
      "import": "./dist/orchestration/index.js",
      "require": "./dist/cjs/orchestration/index.cjs"
    },
    "./redact": {
      "types": "./dist/redact/index.d.ts",
      "import": "./dist/redact/index.js",
      "require": "./dist/cjs/redact/index.cjs"
    },
    "./infra": {
      "types": "./dist/infra/index.d.ts",
      "import": "./dist/infra/index.js",
      "require": "./dist/cjs/infra/index.cjs"
    },
    "./io": {
      "types": "./dist/io/index.d.ts",
      "import": "./dist/io/index.js",
      "require": "./dist/cjs/io/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/cjs/testing/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "fuzz": "vitest run --config vitest.fuzz.config.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:type-level": "tsc --noEmit --project tests/type-level/tsconfig.json",
    "lint": "eslint src/",
    "bench": "NODE_OPTIONS=\"--expose-gc\" tsx tests/perf/bench.ts",
    "bench:update": "NODE_OPTIONS=\"--expose-gc\" UPDATE_BASELINE=1 tsx tests/perf/bench.ts",
    "mutation": "stryker run",
    "mutation:core": "stryker run --mutate 'src/core/agent-loop.ts,src/core/iteration-runner.ts,src/core/adapter-caller.ts'",
    "mutation:core:all": "stryker run --mutate 'src/core/**/*.ts'",
    "mutation:validate": "stryker run --mutate 'src/infra/validate.ts'",
    "mutation:guardrails": "stryker run --mutate 'src/guardrails/pipeline.ts'"
  },
  "devDependencies": {
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "expect-type": "1.3.0",
    "fast-check": "~4.7.0",
    "tinybench": "^6.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "license": "MIT",
  "author": "harness-one contributors",
  "keywords": [
    "ai",
    "agent",
    "harness",
    "llm",
    "framework"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Maitreya001-AI/harness-one",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/Maitreya001-AI/harness-one/issues"
  },
  "homepage": "https://github.com/Maitreya001-AI/harness-one#readme"
}
