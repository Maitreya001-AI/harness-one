      "require": "./dist/cjs/context/index.cjs"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js",
      "require": "./dist/cjs/tools/index.cjs"
    },
    "./guardrails": {
      "types": "./dist/guardrails/index.d.ts",
      "import": "./dist/guardrails/index.js",
      "require": "./dist/cjs/guardrails/index.cjs"
    },
    "./observe": {
      "types": "./dist/observe/index.d.ts",
      "import": "./dist/observe/index.js",
      "require": "./dist/cjs/observe/index.cjs"
    },
    "./session": {
      "types": "./dist/session/index.d.ts",
      "import": "./dist/session/index.js",
      "require": "./dist/cjs/session/index.cjs"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js",
      "require": "./dist/cjs/memory/index.cjs"
