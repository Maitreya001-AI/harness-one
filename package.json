{
  "name": "harness-one-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "scripts": {
    "preinstall": "node tools/check-pnpm.mjs",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test -- --coverage",
    "coverage:html": "pnpm -r test -- --coverage --coverage.reporter=html",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "verify:deps": "tsx tools/verify-deps.ts",
    "check:zero-deps": "node tools/check-zero-deps.mjs",
    "check:pack": "node tools/check-pack-reproducible.mjs",
    "check:migrations": "node tools/check-migrations.mjs",
    "api:update": "pnpm -r --filter \"./packages/*\" exec api-extractor run --local",
    "api:check": "pnpm -r --filter \"./packages/*\" exec api-extractor run",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@microsoft/api-extractor": "^7.47.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.2.0",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^2.0.0"
  },
  "author": "harness-one contributors",
  "keywords": [
    "ai",
    "agent",
    "harness",
    "llm",
    "framework",
    "monorepo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Maitreya001-AI/harness-one"
  },
  "bugs": {
    "url": "https://github.com/Maitreya001-AI/harness-one/issues"
  },
  "homepage": "https://github.com/Maitreya001-AI/harness-one#readme"
}
