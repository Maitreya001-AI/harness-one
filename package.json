{
  "name": "harness-one-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "preinstall": "node tools/check-pnpm.mjs",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test --coverage --coverage.reporter=text --coverage.reporter=html --coverage.reporter=lcov --coverage.reporter=json",
    "coverage:html": "pnpm -r test --coverage --coverage.reporter=html",
    "typecheck": "pnpm -r typecheck",
    "fresh": "pnpm install && pnpm -r --filter './packages/*' build && pnpm typecheck && pnpm test",
    "lint": "pnpm -r lint",
    "smoke": "node tools/smoke-test.mjs",
    "verify:deps": "tsx tools/verify-deps.ts",
    "check:zero-deps": "node tools/check-zero-deps.mjs",
    "check:pack": "node tools/check-pack-reproducible.mjs",
    "check:migrations": "node tools/check-migrations.mjs",
    "examples:smoke": "node tools/run-examples.mjs",
    "check:readme": "node tools/check-readme-snippets.mjs",
    "size": "node tools/size-check/prebundle.mjs && size-limit",
    "size:build": "pnpm build && node tools/size-check/prebundle.mjs",
    "check:tree-shake": "node tools/tree-shake-check/run.mjs",
    "lint:errors": "node tools/lint-error-messages/check.mjs",
    "lint:tsdoc": "node tools/lint-tsdoc/check.mjs",
    "api:update": "pnpm -r --filter \"./packages/*\" exec api-extractor run --local",
    "api:check": "pnpm -r --filter \"./packages/*\" exec api-extractor run",
    "docs:api": "typedoc",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ]
  },
  "pnpm": {
    "overrides": {
      "vite": "^6.4.2",
      "postcss": "^8.5.10"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@harness-one/anthropic": "workspace:*",
    "@harness-one/openai": "workspace:*",
    "@microsoft/api-extractor": "^7.58.7",
    "@size-limit/file": "^12.1.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-import": "^2.31.0",
    "harness-one": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "size-limit": "^12.1.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typedoc": "^0.28.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "author": "harness-one contributors",
  "keywords": [
    "ai",
    "agent",
    "harness",
    "llm",
    "framework",
    "monorepo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Maitreya001-AI/harness-one"
  },
  "bugs": {
    "url": "https://github.com/Maitreya001-AI/harness-one/issues"
  },
  "homepage": "https://github.com/Maitreya001-AI/harness-one#readme"
}
