    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^2.0.0"
  },
  "author": "harness-one contributors",
  "keywords": [
